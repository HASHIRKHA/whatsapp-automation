# ─────────────────────────────────────────────────────────────────────────────
# WA Outreach Engine — API local dev environment
#
# ConfigModule resolves `envFilePath: '.env'` relative to process.cwd(), and
# `pnpm --filter @wa-engine/api dev` (or `nest start` run from this folder)
# sets cwd to apps/api/ — so the API reads apps/api/.env, NOT the repo-root
# .env. Copy this file to apps/api/.env and fill in all REQUIRED values.
#
# (The repo-root .env.example is for Docker Compose / Railway+Vercel, where
# the whole stack shares one env file or platform-injected variables.)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED  Node environment (production | development | test)
NODE_ENV=development

# OPTIONAL  Shared secret for the API key guard (X-API-Key header).
#           Leave empty to disable the guard for local dev.
API_KEY=

# REQUIRED  Keep true until you've verified real sends work correctly.
DRY_RUN=true

# REQUIRED  Domain — used for CORS/SSL only; "localhost" is fine for local dev.
DOMAIN=localhost

# ── Database — Supabase (or any Postgres 16) ──────────────────────────────────

# REQUIRED  Prisma Client connection string.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# REQUIRED  Prisma Migrate connection string (can be the same as DATABASE_URL locally).
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# ── Cache / Queue ─────────────────────────────────────────────────────────────

# REQUIRED  Redis connection URL. Use rediss:// for TLS-required providers
#           (e.g. Upstash) — queue.module.ts auto-enables TLS for that scheme.
#           Local Redis via Docker: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ── Meta Cloud API — Mode 1 (leave empty unless testing Cloud API locally) ────
META_APP_SECRET=
META_VERIFY_TOKEN=dev_verify_token
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=

# ── AI — NEXUS Campaign Brain ─────────────────────────────────────────────────

# REQUIRED  anthropic (default) | openai
AI_PROVIDER=anthropic

# REQUIRED when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# REQUIRED when AI_PROVIDER=openai
OPENAI_API_KEY=

# ── Anti-ban ─────────────────────────────────────────────────────────────────

# REQUIRED  32-byte key for encrypting Baileys session auth state in the DB.
#           Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# REQUIRED  Secret used to sign panel login JWTs. Must match the JWT_SECRET
#           in apps/web/.env.local — the web app's middleware verifies the
#           token with its own copy of this value. If they differ (or the
#           web one is missing), login silently bounces back to /login.
#           Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Queue / Delay engine (sensible local-dev defaults — faster than prod) ─────
DELAY_MEAN_MS=10000
DELAY_STD_DEV_MS=4000
DELAY_FLOOR_MS=5000
DELAY_CEILING_MS=45000
TYPING_SIMULATION_MS=1500
DAILY_SEND_LIMIT=200
PROXY_ROTATION_HOURS=48

# OPTIONAL  IANA timezone for the active-hours gate.
ACTIVE_HOURS_TIMEZONE=Asia/Dubai

# ── Frontend ──────────────────────────────────────────────────────────────────

# REQUIRED  Where the Next.js panel runs locally (CORS + Socket.io origin).
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Server ────────────────────────────────────────────────────────────────────

# OPTIONAL  Port the NestJS API listens on (default: 3001).
PORT=3001

# OPTIONAL  Filesystem path for uploaded media files (default: uploads/).
UPLOAD_DIR=uploads

# OPTIONAL  AI model override — see repo-root .env.example for valid values.
AI_MODEL=
