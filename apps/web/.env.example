# ─────────────────────────────────────────────────────────────────────────────
# WA Outreach Engine — Web panel local dev environment
# Copy this file to apps/web/.env.local and fill in all REQUIRED values.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED  Server-side base URL the catch-all proxy (src/app/api/[...path]/route.ts)
#           forwards every /api/* request to. Not exposed to the browser.
API_URL=http://localhost:3001/api

# REQUIRED  Browser-facing API origin, baked into the JS bundle at build time
#           (used for the Socket.io connection). No /api suffix.
NEXT_PUBLIC_API_URL=http://localhost:3001

# OPTIONAL  Must match API_KEY on the API side, if set there. When set, the
#           proxy route attaches it as the X-API-Key header on every request.
API_KEY=

# REQUIRED  Used by middleware.ts to verify the session JWT cookie issued by
#           the API on login. MUST be byte-for-byte identical to JWT_SECRET
#           in apps/api/.env, or every login will silently bounce back to
#           /login (the cookie gets set, but jwtVerify fails and middleware
#           clears it and redirects — no error is shown to the user).
JWT_SECRET=
